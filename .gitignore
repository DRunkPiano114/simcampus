# macOS
.DS_Store

# Simulation: sim outputs under simulation/ are tracked in git so Vercel
# builds and diff tooling see them; only the debug subtree + high-churn
# runtime files stay out.
/simulation/**/debug/
/simulation/sim.log*
/simulation/costs.jsonl

# Python
__pycache__/
*.pyc
.venv/

# Environment
.env
.env.*
!.env.example

# uv
uv.lock

# development
.claude/

# web
web/node_modules/
web/dist/
.gstack/

# External media: ignore commercial asset packs by default; whitelist
# OFL-licensed fonts so they ship with the repo.
/assets/*
!/assets/fonts/
web/public/assets/
*.tsbuildinfo

# share-card render cache (regenerated from sim data)
.cache/cards/

# self-test outputs (regenerated by `python -m sim.cards.self_test`)
/.cache/self_test/

# left-column calibration outputs (regenerated by scripts/calibrate_left_column.py)
/.cache/left_column_calibration/