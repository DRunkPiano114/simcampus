# ── LLM Provider API Keys (set the one matching your provider) ──
DEEPSEEK_API_KEY=your_api_key_here
# OPENROUTER_API_KEY=sk-or-xxx
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx

# ── Model (default: deepseek/deepseek-chat) ──
# Prefix determines the provider, model name follows provider's convention.
# SIM_LLM_MODEL=deepseek/deepseek-chat
# SIM_LLM_FALLBACK_MODEL=openrouter/google/gemini-3-flash-preview
# SIM_LLM_MODEL=openrouter/deepseek/deepseek-v3.2
# SIM_LLM_MODEL=openai/gpt-4o
# SIM_LLM_MODEL=anthropic/claude-sonnet-4-20250514